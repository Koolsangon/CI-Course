{
  "structure": [
    { "id": "price", "ko": "Price", "en": "Price", "definition": "제품 판매가격", "example": "$200" },
    { "id": "cop", "ko": "COP", "en": "Cost of Product", "definition": "제조원가 = COM + SGA", "example": "$189.7" },
    { "id": "com", "ko": "COM", "en": "Cost of Manufacturing", "definition": "제조원가 = 소요재료비 + 가공비", "example": "$161.3" },
    { "id": "material_cost", "ko": "소요재료비", "en": "Material Cost", "definition": "각 공정 BOM을 해당 공정~최종 누적수율로 나눈 합계", "example": "$90.8" },
    { "id": "processing_cost", "ko": "가공비", "en": "Processing Cost", "definition": "Panel 가공비 + Module 가공비", "example": "$70.5" },
    { "id": "sga", "ko": "SGA", "en": "Selling, General & Administrative", "definition": "판관비 (직접개발비 + 운반비 + 사업부 + Operation + Corporate OH)", "example": "$28.4" },
    { "id": "operating_profit", "ko": "영업이익", "en": "Operating Profit", "definition": "Price - COP", "example": "$10.3" },
    { "id": "cash_cost", "ko": "Cash Cost", "en": "Cash Cost", "definition": "COP - 상각비 합계", "example": "$166.0" },
    { "id": "ebitda", "ko": "EBITDA", "en": "EBITDA", "definition": "Price - Cash Cost", "example": "$34.0" },
    { "id": "variable_cost", "ko": "변동비", "en": "Variable Cost", "definition": "소요재료비 + 변동 가공비 항목", "example": "$91.1" },
    { "id": "marginal_profit", "ko": "한계이익", "en": "Marginal Profit", "definition": "Price - 변동비", "example": "$108.9" },
    { "id": "marginal_rate", "ko": "한계이익률", "en": "Marginal Profit Rate", "definition": "한계이익 / Price", "example": "54.5%" }
  ],
  "parameters": [
    { "id": "bom", "ko": "BOM", "en": "Bill of Materials", "definition": "공정별 부품 단가 (TFT $6, CF $5, Cell $1.5, Module $75)", "impact": "소요재료비 직접 영향" },
    { "id": "yield", "ko": "수율", "en": "Yield", "definition": "공정별 양품률 (TFT 99%, CF 100%, Cell 95%, Module 97.2%)", "impact": "소요재료비 역수 관계" },
    { "id": "cumulative_yield", "ko": "누적수율", "en": "Cumulative Yield", "definition": "해당 공정부터 최종 공정까지의 수율 곱 (전체 91.4%)", "impact": "소요재료비 분모" },
    { "id": "loading", "ko": "Loading", "en": "Loading (가동률)", "definition": "설비 가동률. 기준 70%", "impact": "가공비 반비례 (고정비/생산량)" },
    { "id": "cuts", "ko": "면취수", "en": "Cuts per Sheet", "definition": "원판 1장에서 자를 수 있는 패널 수. 기준 25개", "impact": "BOM(TFT/CF/Cell) + Panel 가공비 반비례" },
    { "id": "mask", "ko": "Mask", "en": "Mask Count", "definition": "포토 공정 마스크 수. 기준 6장", "impact": "Panel 가공비 비례" },
    { "id": "tact", "ko": "Tact", "en": "Tact Time", "definition": "공정 1사이클 소요 시간 배수", "impact": "Module 가공비 비례" },
    { "id": "labor", "ko": "노무비", "en": "Labor Cost", "definition": "인건비. Panel $21.3, Module $8.7", "impact": "가공비 구성요소" },
    { "id": "overhead", "ko": "경비", "en": "Overhead", "definition": "간접비. Panel $11.5, Module $5.3", "impact": "가공비 구성요소" },
    { "id": "depreciation", "ko": "상각비", "en": "Depreciation", "definition": "설비 감가상각. Panel $16.2, Module $7.5", "impact": "가공비 구성요소, Cash Cost 제외 항목" }
  ]
}
